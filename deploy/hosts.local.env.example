# Copy this file to deploy/hosts.local.env on the Vultr control host.
# The local file is gitignored. Do not commit live endpoints, private IPs, tokens,
# Tailscale auth keys or SSH private-key paths from another user's machine.

PROJECT_SLUG=uncertainty
PROJECT_PORT=8787

# Shared, always-on Vultr control host. The public address is used for human SSH;
# workers should reach the dashboard/API through the control host's Tailscale IP.
CONTROL_SSH_ALIAS=vultr-research-control
CONTROL_PUBLIC_HOST=203.0.113.10
CONTROL_SSH_PORT=22
CONTROL_SSH_USER=root

# Elastic AutoDL worker A. The logical role is assigned at task launch time and
# is not permanently tied to solver or training work.
AUTODL1_ALIAS=autodl-worker-a
AUTODL1_HOST=connect.example-a.invalid
AUTODL1_PORT=22222
AUTODL1_USER=root
AUTODL1_NODE_NAME=autodl-worker-a
AUTODL1_REGION=region-a

# Elastic AutoDL worker B.
AUTODL2_ALIAS=autodl-worker-b
AUTODL2_HOST=connect.example-b.invalid
AUTODL2_PORT=33333
AUTODL2_USER=root
AUTODL2_NODE_NAME=autodl-worker-b
AUTODL2_REGION=region-b

# Optional cold-spare worker. Leave every AUTODL3_* variable absent unless a
# third endpoint is intentionally enrolled; it is not part of the two-worker
# baseline or the P0 completion count.
# AUTODL3_ALIAS=autodl-worker-spare
# AUTODL3_HOST=connect.example-spare.invalid
# AUTODL3_PORT=44444
# AUTODL3_USER=root
# AUTODL3_NODE_NAME=autodl-worker-spare
# AUTODL3_REGION=region-b

# One distinct key per AutoDL instance permits independent revocation when an
# instance is rebuilt or its SSH forwarding endpoint changes.
AUTODL_KEY_DIR=/root/.ssh/research-workers
